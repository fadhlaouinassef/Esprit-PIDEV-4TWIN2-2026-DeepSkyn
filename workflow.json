{
  "name": "Skincare Quiz - Robust Looping Flow",
  "nodes": [
    {
      "id": "1",
      "name": "Quiz Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        200,
        300
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "skincare-quiz",
        "responseMode": "lastNode",
        "options": {}
      }
    },
    {
      "id": "2",
      "name": "Sauvegarder Réponse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        400,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3000/api/quiz/save-answer",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"userId\": ($json.body?.userId ?? $json.userId),\n  \"questionId\": ($json.body?.lastQuestionId ?? $json.lastQuestionId),\n  \"answer\": ($json.body?.lastAnswer ?? $json.lastAnswer),\n  \"quizId\": ($json.body?.quizId ?? $json.quizId)\n} }}"
      }
    },
    {
      "id": "3",
      "name": "Récupérer Toutes les Questions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        600,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "http://localhost:3000/api/quiz/questions",
        "options": {}
      }
    },
    {
      "id": "4",
      "name": "Déterminer Prochaine Étape",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        300
      ],
      "parameters": {
        "jsCode": "const questionsData = $node[\"Récupérer Toutes les Questions\"].json;\nlet allQuestions = Array.isArray(questionsData) ? questionsData : (questionsData.questions || []);\n\n// Limit the pool to exactly 10 questions maximum\nconst quizQuestions = allQuestions.slice(0, 10);\n\nconst webhookBody = $node[\"Quiz Webhook\"].json.body || {};\nconst answersSoFar = webhookBody.answersSoFar || [];\n\nconst answeredIds = answersSoFar.map(a => Number(a.questionId));\nconst nextQuestion = quizQuestions.find(q => !answeredIds.includes(Number(q.id)));\n\nif (nextQuestion && answersSoFar.length < 10) {\n  return { status: \"continue\", nextQuestion };\n} else {\n  return { status: \"complete\", answersJSON: JSON.stringify(answersSoFar), questionsJSON: JSON.stringify(quizQuestions) };\n}"
      }
    },
    {
      "id": "5",
      "name": "IF - Quiz Complet ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1000,
        300
      ],
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.status }}",
              "value2": "complete"
            }
          ]
        }
      }
    },
    {
      "id": "6",
      "name": "Gemini - Analyse Finale",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1250,
        200
      ],
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=AIzaSyAKUJaj7-6_2kALSVxc9PK7sFetZjg3vGI",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"Tu es un expert en peau. Questions: \" + $json.questionsJSON + \"\\n\\nRéponses: \" + $json.answersJSON + \"\\n\\nAnalyse l'état de la peau et propose une routine. Retourne un JSON avec skinAnalysis (string) et score (number)/100. Sans markdown.\"\n    }]\n  }],\n  \"generationConfig\": {\n    \"responseMimeType\": \"application/json\",\n    \"temperature\": 0.3\n  }\n} }}"
      }
    },
    {
      "id": "7",
      "name": "Parser Analyse Gemini",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1450,
        200
      ],
      "parameters": {
        "jsCode": "const text = $node[\"Gemini - Analyse Finale\"].json.candidates[0].content.parts[0].text;\ntry {\n  const jsonMatch = text.match(/\\{.*\\}/s);\n  const cleanText = jsonMatch ? jsonMatch[0] : text;\n  const parsed = JSON.parse(cleanText);\n  return { status: \"complete\", analysis: parsed.skinAnalysis, score: parsed.score };\n} catch (e) {\n  return { status: \"complete\", analysis: text, score: 75 };\n}"
      }
    },
    {
      "id": "8",
      "name": "Réponse Continue",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        1250,
        400
      ],
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "continue"
            }
          ],
          "object": [
            {
              "name": "nextQuestion",
              "value": "={{ $json.nextQuestion }}"
            }
          ]
        },
        "keepOnlySet": true
      }
    },
    {
      "id": "9",
      "name": "Merge Réponses",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [
        1700,
        300
      ],
      "parameters": {
        "mode": "append"
      }
    }
  ],
  "connections": {
    "Quiz Webhook": {
      "main": [
        [
          {
            "node": "Sauvegarder Réponse",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Sauvegarder Réponse": {
      "main": [
        [
          {
            "node": "Récupérer Toutes les Questions",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Récupérer Toutes les Questions": {
      "main": [
        [
          {
            "node": "Déterminer Prochaine Étape",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Déterminer Prochaine Étape": {
      "main": [
        [
          {
            "node": "IF - Quiz Complet ?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF - Quiz Complet ?": {
      "main": [
        [
          {
            "node": "Gemini - Analyse Finale",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Réponse Continue",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gemini - Analyse Finale": {
      "main": [
        [
          {
            "node": "Parser Analyse Gemini",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parser Analyse Gemini": {
      "main": [
        [
          {
            "node": "Merge Réponses",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Réponse Continue": {
      "main": [
        [
          {
            "node": "Merge Réponses",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "robust-loop-v1",
  "id": "skincare-quiz-workflow",
  "meta": {
    "instanceId": "1"
  },
  "tags": []
}